package views

import (
	"context"
	"io"

	"testrr/internal/store"
)

templ TestPage(project store.Project, testKey string, history []store.TestHistoryEntry) {
	@Layout("testrr | Test History", &project, templ.ComponentFunc(func(ctx context.Context, w io.Writer) error {
		return TestContent(project, testKey, history).Render(ctx, w)
	}))
}

templ TestContent(project store.Project, testKey string, history []store.TestHistoryEntry) {
	<section class="card bg-base-100 shadow-xl border border-base-200">
		<div class="card-body p-4 sm:p-6 lg:p-8">
			<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
				<div>
					<p class="text-sm font-semibold uppercase tracking-wider text-base-content/60 mb-1">Test history</p>
					<h2 class="text-2xl font-bold font-mono break-all">{ testKey }</h2>
				</div>
				<div class="shrink-0">
					@OutputVisibilityToggle()
				</div>
			</div>

			<div class="min-h-[280px] w-full bg-base-200/50 rounded-2xl border border-base-300 p-2 mb-8" data-chart-endpoint={ testDurationChartURL(project.Slug, testKey) } data-chart-kind="test-duration"></div>
			
			<div class="overflow-x-auto">
				<table class="table w-full">
					<thead>
						<tr class="uppercase text-xs tracking-wider border-b border-base-300">
							<th>Run</th>
							<th>Status</th>
							<th>Duration</th>
							<th>Uploaded</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-base-200">
						for _, entry := range history {
							<tr class="hover">
								<td class="align-top py-4">
									<div class="font-semibold">{ entry.RunLabel }</div>
									<div class="text-xs text-base-content/60 mt-0.5">{ entry.Branch }</div>
								</td>
								<td class="align-top py-4">
									<span class={ "badge badge-sm font-medium " + statusClass(entry.Status) }>{ statusLabel(entry.Status) }</span>
								</td>
								<td class="align-top py-4 text-sm text-base-content/80 whitespace-nowrap">
									{ formatMillis(entry.DurationMillis) }
								</td>
								<td class="align-top py-4 text-sm text-base-content/70 whitespace-nowrap">
									{ formatDate(entry.UploadedAt) }
								</td>
							</tr>
							if entry.FailureMessage != "" || entry.FailureOutput != "" || entry.SystemOut != "" || entry.SystemErr != "" {
								<tr>
									<td colspan="4" class="pb-4 pt-0 border-t-0">
										if entry.FailureMessage != "" {
											<div class="text-sm font-medium text-error bg-error/5 p-3 rounded-lg border border-error/10">
												{ entry.FailureMessage }
											</div>
										}
											<div data-output-block hidden>
												@OutputBlock("Failure output", entry.FailureOutput)
												@OutputBlock("Stdout", entry.SystemOut)
												@OutputBlock("Stderr", entry.SystemErr)
											</div>
										</td>
									</tr>
							}
						}
						if len(history) == 0 {
							<tr>
								<td colspan="4" class="text-center py-8 text-base-content/50 italic">No history found for this test.</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	</section>
}
